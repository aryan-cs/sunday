# ─── LLM PROVIDER ─────────────────────────────────────────────
ACTIVE_LLM_PROVIDER=gemini

# Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# OpenRouter
OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3.1-8b-instruct:free
OPENROUTER_SITE_URL=
OPENROUTER_APP_NAME=Smart Calendar

# Groq
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# Cerebras
CEREBRAS_API_KEY=
CEREBRAS_MODEL=llama3.1-8b

# Ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# Together
TOGETHER_API_KEY=
TOGETHER_MODEL=meta-llama/Meta-Llama-3.1-8B-Instruct-Turbo

# Mistral
MISTRAL_API_KEY=
MISTRAL_MODEL=mistral-small-latest

# Hugging Face
HUGGINGFACE_API_KEY=
HUGGINGFACE_MODEL=mistralai/Mistral-7B-Instruct-v0.3

# Custom OpenAI-compatible endpoint
CUSTOM_LLM_BASE_URL=
CUSTOM_LLM_API_KEY=
CUSTOM_LLM_MODEL=

# ─── GOOGLE ───────────────────────────────────────────────────
GOOGLE_CREDENTIALS_FILE=credentials.json
GOOGLE_TOKEN_FILE=token.json
GOOGLE_MAPS_API_KEY=
# Google Calendar ID to write Sunday-managed events into. Defaults to primary.
TARGET_CALENDAR_ID=primary

# ─── MESSAGING ────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

IMESSAGE_ENABLED=false
# Example: +12175551234 or name@icloud.com
IMESSAGE_RECIPIENT=
TEXT_EMAIL_LINKS=true

# ─── PREFERENCES ──────────────────────────────────────────────
DEFAULT_HOME_LOCATION=Champaign, IL
DEFAULT_HOME_LATITUDE=40.1164
DEFAULT_HOME_LONGITUDE=-88.2434
DEFAULT_WORK_LOCATION=
DEFAULT_WORK_LATITUDE=
DEFAULT_WORK_LONGITUDE=
WORK_DAYS=mon,tue,wed,thu,fri
WORKDAY_START_TIME=09:00
WORKDAY_END_TIME=17:00
PREP_TIME_MINUTES=15
ONLINE_PREP_MINUTES=5
# One of: driving, walking, bicycling, transit
TRAVEL_TYPE=driving
AUTO_CLEANUP_HOURS=24
# Which Gmail inboxes/labels to watch (comma-separated).
# CATEGORY_PRIMARY  — Primary tab only (recommended; ignores promotions/social)
# INBOX             — Everything in the inbox across all tabs
# CATEGORY_SOCIAL, CATEGORY_PROMOTIONS, CATEGORY_UPDATES, CATEGORY_FORUMS
# Custom labels:    use the exact label name, e.g. work,receipts
GMAIL_LABELS=CATEGORY_PRIMARY
# Process recent inbox mail from this many minutes before watcher startup.
GMAIL_INITIAL_LOOKBACK_MINUTES=180
TIMEZONE=America/Chicago
STATE_DIR=.state

# ─── AGENT MODE ───────────────────────────────────────────────
# Controls what happens after Sunday processes an email or voice note.
#   off      — just send the normal summary notification (default)
#   openclaw — push action items to your local OpenClaw agent
#   builtin  — Sunday calls the active LLM directly (with web search)
#              and sends an intelligent insight via iMessage/Telegram
AGENT_MODE=off

# ─── OPENCLAW ─────────────────────────────────────────────────
# Set OPENCLAW_ENABLED=true and point to your local OpenClaw gateway.
# Sunday will push action items from emails and voice notes to the agent.
# Find your hook token in your OpenClaw config under hooks.token.
OPENCLAW_ENABLED=false
OPENCLAW_BASE_URL=http://localhost:3000
OPENCLAW_TOKEN=

# ─── ADVANCED ─────────────────────────────────────────────────
LLM_MAX_TOKENS=1024
LLM_TEMPERATURE=0.3
POLL_INTERVAL_SECONDS=10
MAX_EMAILS_PER_CYCLE=3
LLM_REQUESTS_PER_MINUTE=
LLM_RETRY_ATTEMPTS=4
LLM_RETRY_BASE_SECONDS=5
# Local speech transcription
TRANSCRIPTION_MODEL_PATH=models/transcription/ggml-large-v3-turbo-q5_0.bin
TRANSCRIPTION_LANGUAGE=en
TRANSCRIPTION_THREADS=8
# Local transcript title generation
TRANSCRIPT_TITLE_MODEL_PATH=models/text/qwen2.5-0.5b-instruct
TRANSCRIPT_TITLE_DEVICE=auto
TRANSCRIPT_TITLE_MAX_NEW_TOKENS=12
LOG_LEVEL=INFO
