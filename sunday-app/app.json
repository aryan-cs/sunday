{
  "expo": {
    "name": "Sunday",
    "slug": "sunday",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "CFBundleDisplayName": "Sunday",
        "CFBundleName": "Sunday",
        "ITSAppUsesNonExemptEncryption": false,
        "NSMicrophoneUsageDescription": "Allow Sunday to record your voice so it can transcribe speech.",
        "NSLocationWhenInUseUsageDescription": "Allow Sunday to access your phone location when you enable it in settings.",
        "NSContactsUsageDescription": "Allow Sunday to read your contacts so it can match names and draft/send texts."
      }
    },
    "plugins": [
      "expo-font",
      "expo-audio",
      "expo-contacts",
      "@react-native-community/datetimepicker"
    ],
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    }
  }
}
