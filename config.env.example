# ─── LLM PROVIDER ─────────────────────────────────────────────
ACTIVE_LLM_PROVIDER=gemini

# Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# OpenRouter
OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3.1-8b-instruct:free
OPENROUTER_SITE_URL=
OPENROUTER_APP_NAME=Smart Calendar

# Groq
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# Cerebras
CEREBRAS_API_KEY=
CEREBRAS_MODEL=llama3.1-8b

# Ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# Together
TOGETHER_API_KEY=
TOGETHER_MODEL=meta-llama/Meta-Llama-3.1-8B-Instruct-Turbo

# Mistral
MISTRAL_API_KEY=
MISTRAL_MODEL=mistral-small-latest

# Hugging Face
HUGGINGFACE_API_KEY=
HUGGINGFACE_MODEL=mistralai/Mistral-7B-Instruct-v0.3

# Custom OpenAI-compatible endpoint
CUSTOM_LLM_BASE_URL=
CUSTOM_LLM_API_KEY=
CUSTOM_LLM_MODEL=

# ─── GOOGLE ───────────────────────────────────────────────────
GOOGLE_CREDENTIALS_FILE=credentials.json
GOOGLE_TOKEN_FILE=token.json
GOOGLE_MAPS_API_KEY=

# ─── MESSAGING ────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

IMESSAGE_ENABLED=false
# Example: +12175551234 or name@icloud.com
IMESSAGE_RECIPIENT=
TEXT_EMAIL_LINKS=true
REQUEST_PHONE_LOCATION=false
LOCATION_REQUEST_BASE_URL=
LOCATION_REQUEST_TIMEOUT_SECONDS=20

# ─── PREFERENCES ──────────────────────────────────────────────
DEFAULT_HOME_LOCATION=Champaign, IL
DEFAULT_HOME_LATITUDE=40.1164
DEFAULT_HOME_LONGITUDE=-88.2434
PREP_TIME_MINUTES=15
ONLINE_PREP_MINUTES=5
DEFAULT_TRAVEL_MODE=driving
AUTO_CLEANUP_HOURS=24
GMAIL_LABELS=INBOX
TIMEZONE=America/Chicago
STATE_DIR=.state

# ─── ADVANCED ─────────────────────────────────────────────────
LLM_MAX_TOKENS=1024
LLM_TEMPERATURE=0.3
POLL_INTERVAL_SECONDS=10
MAX_EMAILS_PER_CYCLE=3
LLM_REQUESTS_PER_MINUTE=
LLM_RETRY_ATTEMPTS=4
LLM_RETRY_BASE_SECONDS=5
LOG_LEVEL=INFO
